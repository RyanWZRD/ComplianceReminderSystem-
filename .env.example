# Supabase (v3.0.0 Alpha — cloud mode only)
# Copy to .env for local Supabase CLI or inject at deploy time.
# NEVER commit .env or service role keys.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Service role key: CLI / Edge Functions / migration import ONLY — never in app.bundle.js
# SUPABASE_SERVICE_ROLE_KEY=
