# Supabase (v3.0.0 Alpha Phase 2+)
# Copy to .env, then run: npm run sync-env
# NEVER commit .env, js/data/supabase-env.js, or service role keys.

# Local CLI: supabase status → API URL and anon key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-publishable-key-here

# Staging example (project ref only — use Dashboard anon key, not committed here):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your-staging-anon-key

# Staging test users (create in Supabase Auth + profiles — docs/cloud-setup.md)
# Shared password for all three is typical on staging; use distinct passwords if you prefer.
SUPABASE_TEST_PASSWORD=your-staging-test-password
SUPABASE_TEST_EMAIL=alpha-admin@example.com
SUPABASE_TEST_ROLE=admin
# Optional overrides for verify-cloud-role-load (defaults to alpha-*@example.com)
# SUPABASE_TEST_EMAIL_ADMIN=alpha-admin@example.com
# SUPABASE_TEST_EMAIL_EDITOR=alpha-editor@example.com
# SUPABASE_TEST_EMAIL_VIEWER=alpha-viewer@example.com

# Staging hostnames allowed for ?cloudWrites=1 (comma-separated). Never use on production.
# STAGING_APP_HOSTNAMES=staging.example.com

# Node-only: enable cloud Mark Reminder Sent for verify scripts (default false in app code)
# CLOUD_WRITES_ENABLED=true

# Verify: npm run verify:phase2  (full Phase 2 suite)
# Or: verify-staging-config | verify-cloud-role-load | verify-read-only-guards
# Browser cloud test (after npm run build && serve): http://127.0.0.1:8877/?backend=cloud
# Browser cloud writes (localhost/staging only): ?backend=cloud&cloudWrites=1

# Service role key: CLI / Edge Functions / migration import ONLY — never in the browser bundle
# SUPABASE_SERVICE_ROLE_KEY=
